{
	"info": {
		"_postman_id": "meetings-collabspace-2026",
		"name": "CollabSpace - Meetings API",
		"description": "Meetings module: create meetings, assign teams or individuals, calendar view, upcoming meetings, and notifications.\n\n**Setup:** Run Auth → Login first to save `token`.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "url",
			"value": "http://localhost:8000"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "meeting_id",
			"value": "1"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('token', jsonData.data.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"manager@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": "{{url}}/api/login"
					},
					"response": []
				}
			]
		},
		{
			"name": "Meetings",
			"item": [
				{
					"name": "List Meetings",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{url}}/api/meetings?per_page=15",
							"host": ["{{url}}"],
							"path": ["api", "meetings"],
							"query": [
								{ "key": "per_page", "value": "15" },
								{ "key": "start_date", "value": "2026-06-01", "disabled": true },
								{ "key": "end_date", "value": "2026-06-30", "disabled": true },
								{ "key": "project_id", "value": "1", "disabled": true }
							]
						},
						"description": "List meetings for the authenticated user (creator or participant)."
					},
					"response": []
				},
				{
					"name": "Calendar View",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{url}}/api/meetings/calendar?start_date=2026-06-01&end_date=2026-06-30",
							"host": ["{{url}}"],
							"path": ["api", "meetings", "calendar"],
							"query": [
								{ "key": "start_date", "value": "2026-06-01", "description": "Required" },
								{ "key": "end_date", "value": "2026-06-30", "description": "Required" }
							]
						},
						"description": "Calendar grouped by date with meetings for each day."
					},
					"response": []
				},
				{
					"name": "Upcoming Meetings",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{url}}/api/meetings/upcoming?days=7",
							"host": ["{{url}}"],
							"path": ["api", "meetings", "upcoming"],
							"query": [{ "key": "days", "value": "7" }]
						},
						"description": "Upcoming meetings within the next N days (default 7)."
					},
					"response": []
				},
				{
					"name": "Create Meeting (assign team + individuals)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.meeting && jsonData.data.meeting.id) {",
									"    pm.collectionVariables.set('meeting_id', jsonData.data.meeting.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Sprint Planning\",\n    \"description\": \"Weekly sprint planning session\",\n    \"starts_at\": \"2026-07-01 10:00:00\",\n    \"ends_at\": \"2026-07-01 11:30:00\",\n    \"meeting_link\": \"https://meet.google.com/abc-defg-hij\",\n    \"location\": \"Room A / Online\",\n    \"project_id\": 1,\n    \"team_ids\": [1],\n    \"user_ids\": [3]\n}"
						},
						"url": "{{url}}/api/meetings",
						"description": "Create meeting and notify assigned users. team_ids = full team. user_ids = individual users. Creator is always included."
					},
					"response": []
				},
				{
					"name": "Create Meeting (individuals only)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"1-on-1 Review\",\n    \"description\": \"Performance review\",\n    \"starts_at\": \"2026-07-02 14:00:00\",\n    \"ends_at\": \"2026-07-02 15:00:00\",\n    \"user_ids\": [2, 3]\n}"
						},
						"url": "{{url}}/api/meetings"
					},
					"response": []
				},
				{
					"name": "Get Meeting",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{url}}/api/meetings/{{meeting_id}}"
					},
					"response": []
				},
				{
					"name": "Update Meeting",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Sprint Planning (Updated)\",\n    \"starts_at\": \"2026-07-01 11:00:00\",\n    \"ends_at\": \"2026-07-01 12:00:00\",\n    \"team_ids\": [1],\n    \"user_ids\": [2, 3]\n}"
						},
						"url": "{{url}}/api/meetings/{{meeting_id}}",
						"description": "Only the meeting creator can update. Participants receive update notifications."
					},
					"response": []
				},
				{
					"name": "Delete Meeting",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{url}}/api/meetings/{{meeting_id}}",
						"description": "Only creator can delete. Participants receive cancellation notifications."
					},
					"response": []
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "List Notifications",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": {
							"raw": "{{url}}/api/notifications?per_page=20",
							"host": ["{{url}}"],
							"path": ["api", "notifications"],
							"query": [
								{ "key": "per_page", "value": "20" },
								{ "key": "unread_only", "value": "1", "disabled": true }
							]
						}
					},
					"response": []
				},
				{
					"name": "Mark Notification as Read",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{url}}/api/notifications/{{notification_id}}/read",
						"description": "Replace notification_id with UUID from list response."
					},
					"response": []
				},
				{
					"name": "Mark All as Read",
					"request": {
						"method": "POST",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{url}}/api/notifications/read-all"
					},
					"response": []
				}
			]
		}
	]
}
